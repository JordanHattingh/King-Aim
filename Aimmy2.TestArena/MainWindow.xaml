<Window x:Class="Aimmy2.TestArena.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aimmy Test Arena"
        Width="1280"
        Height="800"
        MinWidth="640"
        MinHeight="480"
        Background="#FF1E1E1E"
        WindowStartupLocation="CenterScreen"
        SizeChanged="Window_SizeChanged"
        SourceInitialized="Window_SourceInitialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="0"
                    Background="#FF2D2D30"
                    Margin="0,0,0,4">
            <TextBlock Text="Scenario:"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="8,6" />
            <ComboBox x:Name="ScenarioComboBox"
                      Width="260"
                      Margin="0,6"
                      Background="#FF3F3F46"
                      Foreground="Black"
                      BorderBrush="#FF5A5A5F"
                      SelectionChanged="ScenarioComboBox_SelectionChanged">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FF3F3F46" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Padding" Value="6,4" />
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FF007ACC" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Resources>
            </ComboBox>

            <CheckBox x:Name="ModelPipelineCheckBox"
                      Content="Run full pipeline (capture -> inference -> tracking -> gamepad)"
                      Foreground="White"
                      VerticalAlignment="Center"
                      Margin="20,0,0,0"
                      Checked="ModelPipelineCheckBox_Changed"
                      Unchecked="ModelPipelineCheckBox_Changed" />

            <TextBlock x:Name="ModelPathLabel"
                       Text="(no model loaded)"
                       Foreground="LightGray"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Canvas x:Name="ArenaCanvas"
                    Grid.Column="0"
                    Background="#FF101010"
                    ClipToBounds="True" />

            <Border Grid.Column="1"
                    Background="#FF252526"
                    BorderBrush="#FF3F3F46"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Diagnostics"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="DiagnosticsText"
                                   Foreground="LightGray"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
