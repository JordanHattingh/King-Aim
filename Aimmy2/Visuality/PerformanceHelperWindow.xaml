<Window x:Class="Visuality.PerformanceHelperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:theme="clr-namespace:Aimmy2.Theme"
        theme:ThemeBehavior.AutoRegister="True"
        mc:Ignorable="d"
        Title="Aimmy Performance Helper"
        Height="178"
        Width="460"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="0"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="SoftPanelBrush" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#24FFFFFF"/>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="FontFamily" Value="{StaticResource Atkinson Hyperlegible}"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4FFFFFF"/>
            <Setter Property="FontFamily" Value="{StaticResource Atkinson Hyperlegible}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LineHeight" Value="19"/>
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="HelperButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="98"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource Atkinson Hyperlegible}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="5"/>
        </Style>
        <Style x:Key="GoalButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource Atkinson Hyperlegible}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid ClipToBounds="True">
        <Border x:Name="MainBorder"
                CornerRadius="5"
                BorderBrush="Black"
                BorderThickness="1"
                Width="460"
                Height="178"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1"
                                     StartPoint="0,0">
                    <GradientStop Color="Black"
                                  Offset="0.25"/>
                    <GradientStop x:Name="ThemeGradientStop"
                                  Color="#FF120338"
                                  Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid x:Name="MiniPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          MouseLeftButtonDown="Header_MouseLeftButtonDown">
                        <Path Fill="White"
                              Stretch="Fill"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Width="20"
                              Height="10"
                              Margin="15,0,0,0"
                              Data="M 18.2472,490.72756 0.18686636,472.66723 153.0173,318.84293 305.84774,165.01862 l 17.74245,17.70593 17.74244,17.70592 17.0189,-16.98112 c 9.36039,-9.33961 17.60957,-16.98112 18.33151,-16.98112 0.72194,0 69.86022,68.54563 153.64061,152.32363 l 152.32798,152.32362 -18.32581,18.45368 -18.3258,18.45368 -152.3021,-153.11064 -152.3021,-153.11063 -20.36457,20.6423 C 309.83073,233.79713 241.18587,302.86906 168.4871,375.93703 L 36.307534,508.7879 Z"/>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="45,0,0,0">
                            <TextBlock Text="Aimmy"
                                       Foreground="#DDFFFFFF"
                                       FontSize="14"
                                       FontFamily="{StaticResource Atkinson Hyperlegible}"/>
                            <TextBlock Text="Performance Helper"
                                       Foreground="#88FFFFFF"
                                       FontSize="12"
                                       FontFamily="{StaticResource Atkinson Hyperlegible}"
                                       Margin="10,1,0,0"/>
                        </StackPanel>
                        <Button x:Name="MiniCloseButton"
                                Content="&#xE8BB;"
                                HorizontalAlignment="Right"
                                Background="{x:Null}"
                                BorderBrush="{x:Null}"
                                Foreground="White"
                                FontFamily="Segoe MDL2 Assets"
                                Padding="15,0,15,0"
                                materialDesign:ButtonAssist.CornerRadius="0,5,5,0"
                                BorderThickness="0"
                                FontSize="10"
                                VerticalAlignment="Center"
                                Click="MiniCloseButton_Click"/>
                    </Grid>

                    <Border Grid.Row="1"
                            CornerRadius="5"
                            Background="{DynamicResource SoftPanelBrush}"
                            BorderBrush="{DynamicResource SoftBorderBrush}"
                            BorderThickness="1"
                            Padding="14"
                            Margin="16,0,16,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="MiniPromptTitle"
                                       Text="Run Performance Helper?"
                                       Foreground="White"
                                       FontFamily="{StaticResource Atkinson Hyperlegible}"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>
                            <TextBlock x:Name="MiniPromptSubtitle"
                                       Text="Benchmark Aimmy once and get a size + FPS cap for this PC."
                                       Foreground="#A8FFFFFF"
                                       FontFamily="{StaticResource Atkinson Hyperlegible}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       LineHeight="17"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid x:Name="MiniFooter"
                          Grid.Row="2"
                          Margin="16,0,16,12">
                        <TextBlock x:Name="MiniFooterText"
                                   Text="Closing will remind you later."
                                   Foreground="#88FFFFFF"
                                   FontFamily="{StaticResource Atkinson Hyperlegible}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,18,0"/>
                        <StackPanel HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="MiniSkipButton"
                                    Style="{StaticResource HelperButton}"
                                    Content="No thanks"
                                    Background="#18FFFFFF"
                                    BorderBrush="#26FFFFFF"
                                    Click="MiniSkipButton_Click"/>
                            <Button x:Name="MiniOpenButton"
                                    Style="{StaticResource HelperButton}"
                                    Content="Run Check"
                                    Margin="10,0,0,0"
                                    Click="MiniOpenButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid x:Name="FullContent"
                      Opacity="0"
                      Visibility="Hidden">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          x:Name="Topbar"
                          MouseLeftButtonDown="Header_MouseLeftButtonDown">
                        <Path Fill="White"
                              Stretch="Fill"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Width="20"
                              Height="10"
                              Margin="15,0,0,0"
                              Data="M 18.2472,490.72756 0.18686636,472.66723 153.0173,318.84293 305.84774,165.01862 l 17.74245,17.70593 17.74244,17.70592 17.0189,-16.98112 c 9.36039,-9.33961 17.60957,-16.98112 18.33151,-16.98112 0.72194,0 69.86022,68.54563 153.64061,152.32363 l 152.32798,152.32362 -18.32581,18.45368 -18.3258,18.45368 -152.3021,-153.11064 -152.3021,-153.11063 -20.36457,20.6423 C 309.83073,233.79713 241.18587,302.86906 168.4871,375.93703 L 36.307534,508.7879 Z"/>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="45,0,0,0">
                            <TextBlock Text="Aimmy"
                                       Foreground="#DDFFFFFF"
                                       FontSize="14"
                                       FontFamily="{StaticResource Atkinson Hyperlegible}"/>
                            <TextBlock Text="Performance Helper"
                                       Foreground="#88FFFFFF"
                                       FontSize="12"
                                       FontFamily="{StaticResource Atkinson Hyperlegible}"
                                       Margin="10,1,0,0"/>
                        </StackPanel>
                        <Button x:Name="CloseButton"
                                Content="&#xE8BB;"
                                HorizontalAlignment="Right"
                                Background="{x:Null}"
                                BorderBrush="{x:Null}"
                                Foreground="White"
                                FontFamily="Segoe MDL2 Assets"
                                Padding="15,0,15,0"
                                materialDesign:ButtonAssist.CornerRadius="0,5,5,0"
                                BorderThickness="0"
                                FontSize="10"
                                VerticalAlignment="Center"
                                Click="CloseButton_Click"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="16,0,16,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0"
                                     Columns="4"
                                     Margin="0,0,0,12">
                            <Border CornerRadius="5"
                                    Background="{DynamicResource SoftPanelBrush}"
                                    BorderBrush="{DynamicResource SoftBorderBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Selected Avg FPS" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="MaxFpsValue" Text="-" Style="{StaticResource MetricValue}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="5"
                                    Background="{DynamicResource SoftPanelBrush}"
                                    BorderBrush="{DynamicResource SoftBorderBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Avg CPU Load" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="CpuValue" Text="-" Style="{StaticResource MetricValue}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="5"
                                    Background="{DynamicResource SoftPanelBrush}"
                                    BorderBrush="{DynamicResource SoftBorderBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Avg GPU Load" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="GpuValue" Text="-" Style="{StaticResource MetricValue}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="5"
                                    Background="{DynamicResource SoftPanelBrush}"
                                    BorderBrush="{DynamicResource SoftBorderBrush}"
                                    BorderThickness="1"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Selected Cap" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="CapValue" Text="-" Style="{StaticResource MetricValue}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="1">
                            <Grid x:Name="IntroPanel">
                                <Border CornerRadius="5"
                                        Background="#10101010"
                                        BorderBrush="#20FFFFFF"
                                        BorderThickness="1"
                                        Padding="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.05*"/>
                                            <ColumnDefinition Width="0.95*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Quick full-speed check"
                                                       Foreground="White"
                                                       FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Aimmy will test image sizes, then recommend a size + FPS cap for your goal. Lower image size can cut resource use, but can lose detail on small targets."
                                                       Foreground="#BFFFFFFF"
                                                       FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       LineHeight="18"
                                                       Margin="0,10,22,0"/>
                                            <TextBlock Text="WHAT DO YOU WANT?"
                                                       Foreground="#88FFFFFF"
                                                       FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                       FontSize="10"
                                                       Margin="0,17,0,8"/>
                                            <UniformGrid Columns="3"
                                                         Margin="0,0,22,0">
                                                <Button x:Name="FastestGoalButton"
                                                        Style="{StaticResource GoalButton}"
                                                        Content="Fastest"
                                                        Tag="FastestDetections"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Freshest detections. Uses more CPU/GPU."
                                                        Click="GoalButton_Click"/>
                                                <Button x:Name="BalancedGoalButton"
                                                        Style="{StaticResource GoalButton}"
                                                        Content="Balanced"
                                                        Tag="Balanced"
                                                        Margin="3,0,3,0"
                                                        ToolTip="Good detection speed with reasonable load."
                                                        Click="GoalButton_Click"/>
                                                <Button x:Name="LowestGoalButton"
                                                        Style="{StaticResource GoalButton}"
                                                        Content="Lowest"
                                                        Tag="LowestResources"
                                                        Margin="6,0,0,0"
                                                        ToolTip="Lowest CPU/GPU use while staying near 60 FPS, or 30 FPS if needed."
                                                        Click="GoalButton_Click"/>
                                            </UniformGrid>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                CornerRadius="5"
                                                Background="{DynamicResource SoftPanelBrush}"
                                                BorderBrush="{DynamicResource SoftBorderBrush}"
                                                BorderThickness="1"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="WHAT HAPPENS"
                                                           Foreground="#88FFFFFF"
                                                           FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                           FontSize="10"/>
                                                <TextBlock Text="5s+ warmup + 10s timed AI loop per size"
                                                           Foreground="White"
                                                           FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                           FontSize="13"
                                                           Margin="0,9,0,0"/>
                                                <TextBlock Text="Mouse movement and clicks stay off"
                                                           Foreground="White"
                                                           FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                           FontSize="13"
                                                           Margin="0,7,0,0"/>
                                                <TextBlock Text="Fastest, Balanced, and Lowest Resource picks are labeled"
                                                           Foreground="White"
                                                           FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                           FontSize="13"
                                                           Margin="0,7,0,0"/>
                                                <TextBlock Text="No training frames are saved"
                                                           Foreground="White"
                                                           FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                           FontSize="13"
                                                           Margin="0,7,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid x:Name="ProgressPanel" Visibility="Collapsed">
                                <Border CornerRadius="5"
                                        Background="#10101010"
                                        BorderBrush="#20FFFFFF"
                                        BorderThickness="1"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock x:Name="ProgressTitle"
                                                   Text="Preparing benchmark"
                                                   Foreground="White"
                                                   FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="ProgressSubtitle"
                                                   Text="Starting..."
                                                   Foreground="#BFFFFFFF"
                                                   FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                   FontSize="12"
                                                   Margin="0,8,0,18"/>
                                        <ProgressBar x:Name="BenchmarkProgressBar"
                                                     Height="7"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="0"
                                                     Foreground="White"
                                                     Background="#20FFFFFF"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid x:Name="ResultsPanel" Visibility="Collapsed">
                                <Border CornerRadius="5"
                                        Background="#10101010"
                                        BorderBrush="#20FFFFFF"
                                        BorderThickness="1"
                                        Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="RecommendationText"
                                                   Text=""
                                                   Foreground="White"
                                                   FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock x:Name="WarningText"
                                                   Grid.Row="1"
                                                   Text=""
                                                   Foreground="#FFFFD27A"
                                                   FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed"
                                                   Margin="0,0,0,10"/>
                                        <ScrollViewer Grid.Row="2"
                                                      VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="ResultsStack"/>
                                        </ScrollViewer>
                                        <TextBlock x:Name="FixedModelNote"
                                                   Grid.Row="3"
                                                   Text=""
                                                   Foreground="#88FFFFFF"
                                                   FontFamily="{StaticResource Atkinson Hyperlegible}"
                                                   FontSize="11"
                                                   Margin="0,8,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="16,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FooterText"
                                   Text="You can change these later in Model Settings."
                                   Foreground="#78FFFFFF"
                                   FontFamily="{StaticResource Atkinson Hyperlegible}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="NoThanksButton"
                                    Style="{StaticResource HelperButton}"
                                    Content="No Thanks"
                                    Margin="0,0,10,0"
                                    Click="NoThanksButton_Click"/>
                            <Button x:Name="RunTestButton"
                                    Style="{StaticResource HelperButton}"
                                    Content="Run Test"
                                    Click="RunTestButton_Click"/>
                            <Button x:Name="ApplyButton"
                                    Style="{StaticResource HelperButton}"
                                    Content="Apply Settings"
                                    Margin="10,0,0,0"
                                    Visibility="Collapsed"
                                    Click="ApplyButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
